---
import "../styles/global.css";

const {
  title = "Mimarya | Mimarlık ve İç Mekan Tasarım Stüdyosu",
  description = "Mimarya, konut, ticari mekan ve iç mimarlık projelerinde fikirden uygulamaya rafine tasarım hizmetleri sunan mimarlık stüdyosudur.",
  canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.href,
  image = "/assets/hero.png"
} = Astro.props;

const absoluteImage = Astro.site ? new URL(image, Astro.site).toString() : image;

const schema = {
  "@context": "https://schema.org",
  "@type": "ArchitecturalService",
  name: "Mimarya",
  url: canonical,
  image: absoluteImage,
  description,
  areaServed: "Turkey",
  email: "hello@mimarya.com",
  serviceType: ["Mimari Tasarım", "İç Mekan Tasarımı", "Proje Yönetimi"],
  sameAs: []
};
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preload" href="/assets/hero.png" as="image" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="tr_TR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={absoluteImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <slot />
  </body>
</html>
