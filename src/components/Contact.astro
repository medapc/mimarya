<section id="contact" class="contact">
  <div>
    <p class="eyebrow">Contact</p>
    <h2>Yeni bir mekan fikrini konuşalım.</h2>
    <div class="contact-details" aria-label="İletişim bilgileri">
      <a href="mailto:info@mimarya.com">info@mimarya.com</a>
      <a href="tel:+905307013851">+90 530 701 38 51</a>
    </div>
  </div>
  <form name="contact" method="post">
    <label>
      <span>Ad Soyad</span>
      <input name="name" autocomplete="name" required />
    </label>
    <label>
      <span>Telefon</span>
      <input name="phone" autocomplete="tel" required />
    </label>
    <label>
      <span>E-posta</span>
      <input name="email" type="email" autocomplete="email" required />
    </label>
    <label class="full">
      <span>Proje Notu</span>
      <textarea name="message" rows="4"></textarea>
    </label>
    <button type="submit">Gönder</button>
  </form>
</section>
